# ──── Database ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/educrm_db

# ──── Redis ───────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ──── JWT ─────────────────────────────────────────────
SECRET_KEY=super-secret-key-minimum-32-characters-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──── App ─────────────────────────────────────────────
APP_ENV=development
DEBUG=true
WORKERS=2
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ──── File Storage ────────────────────────────────────
MEDIA_ROOT=./media
MAX_UPLOAD_SIZE_MB=5

# ──── DigitalOcean Spaces (prod da yoqish) ────────────
USE_SPACES=false
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=fra1
DO_SPACES_BUCKET=educrm-media
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
