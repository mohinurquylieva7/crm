# ──────────────────────────────────────────────────────────────
# EduCRM Pro — Production Environment Variables
# terraform output dan olinadigan qiymatlar (*) bilan belgilangan
# ──────────────────────────────────────────────────────────────

# ── Database (*) ──────────────────────────────────────────────
# terraform output postgres_uri  (sensitive — -raw bilan oling)
DATABASE_URL=postgresql+asyncpg://educrm_user:STRONG_PASSWORD@private-db-host.db.ondigitalocean.com:25060/educrm_db?ssl=require

# ── Redis (*) ─────────────────────────────────────────────────
# terraform output redis_uri (sensitive)
REDIS_URL=rediss://:REDIS_PASSWORD@private-redis-host.db.ondigitalocean.com:25061

# ── JWT ───────────────────────────────────────────────────────
# openssl rand -hex 32  bilan yarating
SECRET_KEY=CHANGE-ME-GENERATE-WITH-OPENSSL-RAND-HEX-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
WORKERS=2
# Frontendingiz domeni yoki IP
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── File Storage ──────────────────────────────────────────────
MEDIA_ROOT=/opt/educrm/media
MAX_UPLOAD_SIZE_MB=5

# ── DigitalOcean Spaces (*) ───────────────────────────────────
# DO Console → Spaces → Manage Keys da yarating
USE_SPACES=true
DO_SPACES_KEY=YOUR_SPACES_ACCESS_KEY
DO_SPACES_SECRET=YOUR_SPACES_SECRET_KEY
# terraform output spaces_bucket_name
DO_SPACES_REGION=fra1
DO_SPACES_BUCKET=educrm-media
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
